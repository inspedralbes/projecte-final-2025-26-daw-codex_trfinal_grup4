# =============================================================
#  Variables de entorno – PRODUCCIÓN
#  ⚠️  IMPORTANTE: Cambiar TODOS los valores por defecto
#  antes de desplegar. NO commitear este archivo con secretos.
# =============================================================

# --- App ---
APP_NAME=TFG
APP_ENV=production
APP_DEBUG=false
APP_URL=https://tu-dominio.com

# --- Base de datos ---
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_STRONG_PASSWORD
DB_DATABASE=tfg_database
DB_USERNAME=tfg_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_HOST=mysql
DB_PORT=3306

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# --- Mail ---
MAIL_MAILER=smtp
MAIL_HOST=smtp.tu-proveedor.com
MAIL_PORT=587
MAIL_USERNAME=tu-email@dominio.com
MAIL_PASSWORD=CHANGE_ME_MAIL_PASSWORD
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@tu-dominio.com
MAIL_FROM_NAME="${APP_NAME}"

# --- Socket ---
SOCKET_PORT=3000
