# =============================================================
#  Variables de entorno – PRODUCCIÓN
#  ⚠️  IMPORTANTE: 
#    1. Cambiar TODOS los valores marcados con CHANGE_ME
#    2. Generar APP_KEY seguro: php artisan key:generate
#    3. NO commitear este archivo con secretos reales
#    4. Copiar a .env en el servidor de producción
# =============================================================

# --- App ---
APP_NAME=Codex
APP_ENV=production
APP_DEBUG=false
APP_URL=https://tu-dominio.com
APP_KEY=base64:CHANGE_ME_GENERATE_WITH_php_artisan_key:generate

# --- Domain (para Let's Encrypt y nginx) ---
DOMAIN=tu-dominio.com

# --- Database ---
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=tfg_database
DB_USERNAME=tfg_user
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_STRONG_PASSWORD

# --- Redis (caché, sessions, pub-sub) ---
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# --- Mail (configurar con tu proveedor SMTP) ---
MAIL_MAILER=smtp
MAIL_HOST=smtp.tu-proveedor.com
MAIL_PORT=587
MAIL_USERNAME=tu-email@dominio.com
MAIL_PASSWORD=CHANGE_ME_MAIL_PASSWORD
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@tu-dominio.com
MAIL_FROM_NAME="${APP_NAME}"

# --- Cache & Sessions ---
CACHE_STORE=redis
SESSION_DRIVER=cookie
QUEUE_CONNECTION=redis

# --- Broadcast & Socket ---
BROADCAST_DRIVER=redis
SOCKET_PORT=3000
SOCKET_URL=https://tu-dominio.com/socket.io/

# --- Authentication - Google OAuth ---
GOOGLE_CLIENT_ID=CHANGE_ME_GENERATE_IN_GOOGLE_CLOUD_CONSOLE
GOOGLE_CLIENT_SECRET=CHANGE_ME_GENERATE_IN_GOOGLE_CLOUD_CONSOLE
GOOGLE_REDIRECT_URI=https://tu-dominio.com/auth/google/callback

# --- URLs ---
FRONTEND_URL=https://tu-dominio.com
API_URL=https://tu-dominio.com/api

# --- CORS & Security ---
SANCTUM_STATEFUL_DOMAINS=tu-dominio.com
SANCTUM_ENCRYPT_COOKIES=true

# --- Vite (Frontend) ---
VITE_API_URL=https://tu-dominio.com/api
VITE_SOCKET_URL=https://tu-dominio.com
VITE_GOOGLE_CLIENT_ID=CHANGE_ME_GENERATE_IN_GOOGLE_CLOUD_CONSOLE

# --- Logging ---
LOG_CHANNEL=stack
LOG_LEVEL=error

# --- Timezone ---
APP_LOCALE=es
TIMEZONE=UTC

