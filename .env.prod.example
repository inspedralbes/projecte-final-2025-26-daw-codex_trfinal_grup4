# =============================================================
#  Variables de entorno – PRODUCCIÓN
#  ──────────────────────────────────────────────────────────
#  UN ÚNICO .env en la raíz del proyecto (/opt/codex/.env)
#  Docker Compose lo lee automáticamente.
#  ⚠️  Cambiar TODOS los valores marcados con CHANGE_ME
#  ⚠️  NO commitear este archivo con secretos reales
# =============================================================

# --- App (Laravel) ---
APP_NAME=Codex
APP_ENV=production
APP_DEBUG=false
APP_URL=https://codex.daw.inspedralbes.cat
APP_KEY=base64:CHANGE_ME_GENERATE_WITH_php_artisan_key:generate

# --- Domain (Nginx + Let's Encrypt) ---
DOMAIN=codex.daw.inspedralbes.cat

# --- Database ---
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=codex
DB_USERNAME=codex_user
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_STRONG_PASSWORD

# --- Redis ---
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# --- Mail (Hestia Mail Server) ---
MAIL_MAILER=smtp
MAIL_HOST=daw.inspedralbes.cat
MAIL_PORT=587
MAIL_USERNAME=noreply@codex.daw.inspedralbes.cat
MAIL_PASSWORD=CHANGE_ME_HESTIA_MAIL_PASSWORD
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@codex.daw.inspedralbes.cat
MAIL_FROM_NAME="${APP_NAME}"

# --- Cache & Sessions ---
CACHE_STORE=redis
SESSION_DRIVER=cookie
QUEUE_CONNECTION=redis

# --- Broadcast & Socket ---
BROADCAST_DRIVER=redis
SOCKET_PORT=3000
SOCKET_URL=https://codex.daw.inspedralbes.cat/socket.io/

# --- Google OAuth ---
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_REDIRECT_URI=https://codex.daw.inspedralbes.cat/auth/google/callback

# --- URLs ---
FRONTEND_URL=https://codex.daw.inspedralbes.cat
API_URL=http://api:80

# --- CORS & Sanctum ---
SANCTUM_STATEFUL_DOMAINS=codex.daw.inspedralbes.cat
SANCTUM_ENCRYPT_COOKIES=true

# --- Vite (Frontend – build time) ---
VITE_API_URL=https://codex.daw.inspedralbes.cat/api
VITE_SOCKET_URL=https://codex.daw.inspedralbes.cat
VITE_GOOGLE_CLIENT_ID=CHANGE_ME

# --- Logging ---
LOG_CHANNEL=stack
LOG_LEVEL=error

# --- Timezone ---
APP_LOCALE=es
TIMEZONE=UTC

# --- AI Moderation (Post bans) ---
AI_MODERATION_ENABLED=true
AI_MODERATION_URL=http://ai-moderation:8088
AI_MODERATION_API_KEY=CHANGE_ME_OPTIONAL_INTERNAL_KEY
AI_MODERATION_TIMEOUT_SECONDS=4
AI_MODERATION_FAIL_OPEN=true
AI_MODERATION_TIMEOUT_HOURS=24
AI_MODERATION_TIMEOUT_AFTER_STRIKES=2
AI_MODERATION_BAN_AFTER_STRIKES=4
AI_MODERATION_CRITICAL_AUTO_BAN=true

AI_MODEL_ID=Xenova/toxic-bert
AI_MODEL_ENABLED=true
AI_ZERO_SHOT_ENABLED=true
AI_ZERO_SHOT_MODEL_ID=MoritzLaurer/mDeBERTa-v3-base-mnli-xnli
AI_ZERO_SHOT_BLOCK_THRESHOLD=0.52

AI_LLM_ENABLED=false
AI_LLM_BASE_URL=https://api.openai.com/v1
AI_LLM_API_KEY=CHANGE_ME_LLM_API_KEY
AI_LLM_MODEL=gpt-4o-mini

AI_BLOCK_THRESHOLD=0.72
AI_MEDIUM_THRESHOLD=0.45
AI_HIGH_THRESHOLD=0.65
AI_CRITICAL_THRESHOLD=0.85
AI_MAX_TEXT_LENGTH=6000
