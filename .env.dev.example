# =============================================================
#  Variables de entorno – DESARROLLO
#  Copiar a .env para usar con docker-compose.dev.yml
#  Este archivo es un EJEMPLO – NUNCA subir .env.dev con credenciales reales
# =============================================================

# --- App ---
APP_NAME=Codex
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080
FRONTEND_URL=http://localhost:5173

# --- Base de datos ---
DB_ROOT_PASSWORD=rootpassword
DB_DATABASE=tfg_database
DB_USERNAME=tfg_user
DB_PASSWORD=tfg_password
DB_HOST=mysql
DB_PORT=3306

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Mail (Mailpit) ---
MAIL_MAILER=smtp
# En api/.env (solo para probar, luego revertir)
MAIL_HOST=mail.codex.daw.inspedralbes.cat
MAIL_PORT=587
MAIL_USERNAME=noreply@codex.daw.inspedralbes.cat
MAIL_PASSWORD=WnAsiiYlhYkxH66o1LTAbtHb27825mBMHqEqfx4CsD043K6f54
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@tfg.local
MAIL_FROM_NAME="${APP_NAME}"

# --- Socket ---
SOCKET_PORT=3000

# --- Google OAuth ---
# Reemplazar con tus propias credenciales de Google Cloud Console
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback

# --- Vite ---
VITE_API_URL=http://localhost:8080/api
VITE_SOCKET_URL=http://localhost:8080
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE

# --- AI Moderation ---
AI_MODERATION_ENABLED=true
AI_MODERATION_URL=http://ai-moderation:8088
AI_MODERATION_API_KEY=
AI_MODERATION_TIMEOUT_SECONDS=4
AI_MODERATION_FAIL_OPEN=true
AI_MODERATION_TIMEOUT_HOURS=24
AI_MODERATION_TIMEOUT_AFTER_STRIKES=2
AI_MODERATION_BAN_AFTER_STRIKES=4
AI_MODERATION_CRITICAL_AUTO_BAN=true

AI_MODEL_ID=Xenova/toxic-bert
AI_MODEL_ENABLED=true
AI_ZERO_SHOT_ENABLED=true
AI_ZERO_SHOT_MODEL_ID=MoritzLaurer/mDeBERTa-v3-base-mnli-xnli
AI_ZERO_SHOT_BLOCK_THRESHOLD=0.52

AI_LLM_ENABLED=false
AI_LLM_BASE_URL=https://api.openai.com/v1
AI_LLM_API_KEY=
AI_LLM_MODEL=gpt-4o-mini

AI_BLOCK_THRESHOLD=0.72
AI_MEDIUM_THRESHOLD=0.45
AI_HIGH_THRESHOLD=0.65
AI_CRITICAL_THRESHOLD=0.85
AI_MAX_TEXT_LENGTH=6000
