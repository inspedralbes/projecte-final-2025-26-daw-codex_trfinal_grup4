# =============================================================
#  .gitignore – React Client (Vite)
# =============================================================

# --- Environment variables (NUNCA subir) ---
.env
.env.local
.env.*.local

# --- Dependencies ---
node_modules/
package-lock.json

# --- Build output ---
dist/
build/

# --- IDE ---
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Testing ---
coverage/
.nyc_output/

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Development ---
.env.development.local
.vite/
